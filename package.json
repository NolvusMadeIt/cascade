{
  "name": "cascade",
  "displayName": "Cascade — Free AI Models",
  "description": "AI coding assistant powered by free-tier models from OpenRouter, Hugging Face, and Groq. No paid plan required.",
  "version": "1.3.1",
  "publisher": "NolvusMadeIt",
  "repository": {
    "type": "git",
    "url": "https://github.com/NolvusMadeIt/cascade.git"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "chat",
    "openrouter",
    "huggingface",
    "groq",
    "free",
    "llm",
    "coding"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cascade-container",
          "title": "Cascade AI",
          "icon": "media/cascade-icon.svg"
        }
      ],
      "panel": [
        {
          "id": "cascade-panel-container",
          "title": "Cascade",
          "icon": "media/cascade-icon.svg"
        }
      ],
      "auxiliarybar": [
        {
          "id": "cascade-secondary-container",
          "title": "Cascade",
          "icon": "media/cascade-icon.svg"
        }
      ]
    },
    "views": {
      "cascade-container": [
        {
          "type": "webview",
          "id": "cascade.chat",
          "name": "Cascade"
        }
      ],
      "cascade-panel-container": [
        {
          "type": "webview",
          "id": "cascade.panel",
          "name": "Cascade"
        }
      ],
      "cascade-secondary-container": [
        {
          "type": "webview",
          "id": "cascade.secondary",
          "name": "Cascade"
        }
      ]
    },
    "commands": [
      {
        "command": "cascade.newChat",
        "title": "Cascade: New Chat"
      },
      {
        "command": "cascade.openSettings",
        "title": "Cascade: Open Settings"
      },
      {
        "command": "cascade.clearHistory",
        "title": "Cascade: Clear All History"
      },
      {
        "command": "cascade.focusSidebar",
        "title": "Cascade: Move/Focus in Sidebar",
        "category": "Cascade"
      },
      {
        "command": "cascade.focusPanel",
        "title": "Cascade: Move/Focus in Bottom Panel",
        "category": "Cascade"
      },
      {
        "command": "cascade.focusSecondary",
        "title": "Cascade: Move/Focus in Secondary Sidebar",
        "category": "Cascade"
      }
    ],
    "configuration": {
      "title": "Cascade",
      "properties": {
        "cascade.provider": {
          "type": "string",
          "enum": [
            "openrouter",
            "huggingface",
            "groq"
          ],
          "default": "openrouter",
          "description": "Default AI provider"
        },
        "cascade.model": {
          "type": "string",
          "default": "meta-llama/llama-3.3-70b-instruct:free",
          "description": "Model identifier for the selected provider"
        },
        "cascade.temperature": {
          "type": "number",
          "default": 0.2,
          "minimum": 0,
          "maximum": 2,
          "description": "Sampling temperature"
        },
        "cascade.maxTokens": {
          "type": "number",
          "default": 4096,
          "minimum": 256,
          "maximum": 128000,
          "description": "Maximum tokens to generate"
        },
        "cascade.topP": {
          "type": "number",
          "default": 1,
          "minimum": 0.01,
          "maximum": 1,
          "description": "Top-p nucleus sampling"
        },
        "cascade.fileAccess": {
          "type": "string",
          "enum": [
            "none",
            "read",
            "readwrite"
          ],
          "default": "none",
          "description": "Allow reading or writing workspace files"
        },
        "cascade.fileScope": {
          "type": "string",
          "enum": [
            "workspace",
            "anywhere"
          ],
          "default": "workspace",
          "description": "Scope of file access"
        },
        "cascade.terminalAccess": {
          "type": "boolean",
          "default": false,
          "description": "Allow running terminal commands"
        },
        "cascade.approvalMode": {
          "type": "string",
          "enum": [
            "ask",
            "auto",
            "chat"
          ],
          "default": "ask",
          "description": "How file/terminal actions are approved"
        },
        "cascade.gitAccess": {
          "type": "boolean",
          "default": false,
          "description": "Allow git operations (status, diff, commit, push)"
        },
        "cascade.openRouterFreeOnly": {
          "type": "boolean",
          "default": true,
          "description": "Restrict OpenRouter model list to free ($0) models only"
        },
        "cascade.fallbackProvider": {
          "type": "string",
          "enum": [
            "none",
            "openrouter",
            "huggingface",
            "groq"
          ],
          "default": "none",
          "description": "Fallback provider when the active one fails or has no key"
        },
        "cascade.contextLength": {
          "type": "number",
          "default": 20,
          "minimum": 2,
          "maximum": 50,
          "description": "Number of previous messages sent as context"
        },
        "cascade.userName": {
          "type": "string",
          "default": "",
          "description": "Your name — Cascade will address you by it"
        },
        "cascade.systemPrompt": {
          "type": "string",
          "default": "",
          "description": "Custom text appended to Cascade's system prompt"
        },
        "cascade.historyRetention": {
          "type": "string",
          "enum": [
            "unlimited",
            "30",
            "7",
            "none"
          ],
          "default": "unlimited",
          "description": "How long to keep chat history"
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "cascade.focusSidebar",
          "when": "view == cascade.panel || view == cascade.secondary",
          "group": "navigation@99"
        },
        {
          "command": "cascade.focusPanel",
          "when": "view == cascade.chat || view == cascade.secondary",
          "group": "navigation@99"
        },
        {
          "command": "cascade.focusSecondary",
          "when": "view == cascade.chat || view == cascade.panel",
          "group": "navigation@99"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "dompurify": "^3.1.0",
    "marked": "^12.0.0"
  }
}
